#!/bin/sh
set -eu

if [ "$#" -ne 1 ]; then
  echo "Usage: commit-msg <path-to-commit-message>" >&2
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel)"
validator="${repo_root}/scripts/validate_commit_msg.ps1"
bash_validator="${repo_root}/scripts/validate_commit_msg.sh"

if command -v pwsh >/dev/null 2>&1 && [ -f "${validator}" ]; then
  pwsh -NoProfile -File "${validator}" "$1"
  exit $?
fi

if command -v bash >/dev/null 2>&1 && [ -f "${bash_validator}" ]; then
  bash "${bash_validator}" "$1"
  exit $?
fi

echo "No usable commit validator found (expected pwsh+${validator} or bash+${bash_validator})." >&2
exit 1
